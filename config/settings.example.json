{
  "comfyui_base_url": "http://127.0.0.1:8188",
  "anime_api": {
    "provider": "openai",
    "base_url": "https://aigate.zhixingjidian.cn",
    "api_key_env": "OPENAI_API_KEY",
    "model": "gpt-image-2",
    "default_style_preset": "clean_anime_drama"
  },
  "paths": {
    "source_frames": "data/assets/source_frames",
    "anime_frames": "data/assets/anime_frames",
    "api_metadata": "data/assets/api_metadata",
    "exports": "data/exports"
  },
  "export_presets": {
    "douyin": {
      "width": 1080,
      "height": 1920,
      "seconds_per_frame": 2
    },
    "bilibili": {
      "width": 1920,
      "height": 1080,
      "seconds_per_frame": 3
    }
  }
}
